  m_Script: {fileID: 11500000, guid: dd88718e72c264f4a9e3b99cfff25ca2, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::SystemRPGnormal
  panel: {fileID: 684994836}
  perguntaText: {fileID: 1007355977}
  opcoesText:
  - {fileID: 1779001712}
  - {fileID: 132068668}
  feedbackText: {fileID: 48416039}
  velocidadeTexto: 0.03
  vidaMaxima: 3
  acertosMinimos: 2
  estaAtivo: 0
  dialogueSystem: {fileID: 1824086557}
  falasVitoria:
  - "Chefe: Bom, sr. Franz. O emprego \xE9 seu. "
  falasDerrota:
  - 'Chefe: Hm, temos candidatos melhores.'
  player: {fileID: 1571093871}
  pontoRespawn: {fileID: 1643286954}
  perguntas:
  - pergunta: "Chefe: Primeiramente, dando uma olhada aqui no seu curr\xEDculo percebi
      que voc\xEA disse que sabe ingl\xEAs, certo? \u2606 Gostaria que voc\xEA me
      falasse uma pequena frase como uma prova \u2606 "
    opcoes:
    - 'Franz: Hi sir, im ready to work in this company. '
    - "Franz: Hola se\xF1or, estoy listo para empezar a trabajar en esta empresa."
    respostaCorreta: 0
    feedbackCorreto: "Chefe: Voc\xEA o satisfez; "
    feedbackErrado: "Chefe:  ele n\xE3o parece satisfeito; "
  - pergunta: "Chefe: Ok, aqui voc\xEA tamb\xE9m diz ser r\xE1pido em c\xE1lculos 
      matem\xE1ticos \u2606 Vou te dar uma pequena equa\xE7\xE3o e quero que me responda:
      246+34. "
    opcoes:
    - 'Franz: 302.'
    - 'Franz: 280. '
    respostaCorreta: 1
    feedbackCorreto: 'Chefe:  Ele parece feliz; '
    feedbackErrado: "Chefe: Voc\xEA irritou ele, n\xE3o era t\xE3o dif\xEDcil; "
  - pergunta: "Chefe: Apenas uma d\xFAvida, com qual animal voc\xEA se identifica? "
    opcoes:
    - "Franz: Com certeza um le\xE3o, senhor. "
    - 'Franz: Talvez uma galinha..? '
    respostaCorreta: 0
    feedbackCorreto: "Chefe: Ele est\xE1 orgulhoso; "
    feedbackErrado: 'Chefe: Ele parece enojado..?; '
  - pergunta: "Chefe: Ok, apenas mais uma pergunta. \u2606 Voc\xEA tem algum problema
      de sa\xFAde que ir\xE1 interferir na qualidade do seu trabalho? "
    opcoes:
    - "Franz: N\xE3o, senhor. "
    - 'Franz: Sim, senhor. '
    respostaCorreta: 0
    feedbackCorreto: "Chefe: Acho que ele n\xE3o gostou disso\u2026; "
    feedbackErrado: 'Chefe: Ele parece satisfeito; '
  objetoAtivar: {fileID: 1254072416}
  objetoDesativar: {fileID: 2093832542}
